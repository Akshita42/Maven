# ─────────────────────────────────────────────
# Maven Backend — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Server ──────────────────────────────────
NODE_ENV=development
PORT=4000

# ── CORS ────────────────────────────────────
# The exact origin of the React frontend.
# In production this will be your deployed frontend URL.
CORS_ORIGIN=http://localhost:3000

# ── AI Service (Python FastAPI) ──────────────
# Base URL of the Python AI service.
# Not used in Phase 1 — required from Phase 2 onward.
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_TIMEOUT=30000
